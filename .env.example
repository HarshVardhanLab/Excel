COMMAND_LOG_WEBHOOK=https://discord.com/api/webhooks/your_command_log_webhook
ROLE_LOG_WEBHOOK=https://discord.com/api/webhooks/your_role_log_webhook

# Redis (Optional)
REDIS_URL=redis://username:password@host:port/0

# Bot Configuration
OWNER_IDS=870040788539678791
