# Discord Bot Configuration
TOKEN=your_discord_bot_token_here
PREFIX=$

# Database
MONGO_DB=mongodb+srv://username:password@cluster.mongodb.net

# Webhooks
WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url
